# Copier-update drift detection for {{ plugin_full_name }}.
#
# Generated from livespec/templates/orchestrator-plugin/.github/workflows/
# copier-update-drift.yml.jinja at copier-copy time; re-sync via
# `copier update --vcs-ref=master` when the livespec template changes.
#
# Authority: livespec/SPECIFICATION/contracts.md
#   §"Shared content sync — copier template" — each impl repo's CI
#   SHOULD run `copier update --dry-run` and fail or warn on detected
#   drift.
#
# This workflow surfaces drift between {{ plugin_full_name }}'s
# generated content and livespec's current template. To re-sync
# after detected drift: run `copier update --vcs-ref=master` locally
# and resolve any 3-way merge conflicts.
#
# The `--vcs-ref=master` pin is load-bearing: a bare `copier update`
# resolves the latest git TAG on the template repo (livespec's v1.0.0,
# which predates the entire template workflow set); the family's
# blessed re-sync ref is master.

name: copier-update-drift

on:
  pull_request:
  push:
    branches: [master]
  schedule:
    # Weekly drift sweep — catches livespec template changes
    # that haven't been propagated to {{ plugin_full_name }} via PR yet.
    - cron: "0 12 * * 1"

jobs:
  drift:
    name: copier update --dry-run --vcs-ref=master
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install pinned binaries via mise
        uses: jdx/mise-action@v2

      - name: Install Python dev deps via uv (includes copier)
        run: uv sync --all-groups

      - name: copier update --dry-run --vcs-ref=master
        run: |
          set -uo pipefail
          uv run copier update \
            --dry-run \
            --defaults \
            --skip-answered \
            --vcs-ref=master
