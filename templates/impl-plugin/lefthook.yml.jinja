# lefthook.yml — {{ plugin_full_name }} git hook configuration.
#
# Generated from livespec/templates/impl-plugin/lefthook.yml.jinja
# at copier-copy time; re-sync via `copier update --vcs-ref=master` when livespec
# publishes a new release.
#
# Authority: livespec/SPECIFICATION/contracts.md
#   §"Pre-commit step ordering" — pre-commit runs the refuse-primary-commit
#   gate FIRST, then three commands in order (00-lint-autofix-staged,
#   01-commit-pairs-source-and-test, 02-check-pre-commit); commit-msg runs
#   the refuse-primary-commit backstop then red-green-replay (v034 D3);
#   pre-push runs the full aggregate.
#
# Worktree-discipline gate: `dev-tooling/refuse-primary-commit.sh` refuses
# any commit made on the PRIMARY checkout (the worktree-only repository
# mutation protocol; see AGENTS.md §"Repository mutation protocol"). It is
# wired BOTH as the first pre-commit job AND as a commit-msg backstop — the
# backstop catches `git commit --allow-empty`, which lefthook v2 skips at
# pre-commit because it skips pre-commit jobs when there are zero staged
# files. The gate distinguishes primary from linked worktree with portable,
# config-free `git rev-parse --git-common-dir` vs `--git-dir` detection
# (linked worktrees pass; the script exits 0 there); it needs no
# `livespec.primaryPath` config and is runner-agnostic (it does NOT delegate
# to `just`).
#
# Authority: livespec/SPECIFICATION/non-functional-requirements.md
#   §"Toolchain pins" — `run:` fields MUST delegate to `just <target>`
#   and MUST NOT shell out to underlying tools directly (the spec's
#   lefthook-must-delegate-to-just rule, enforced by
#   dev-tooling/checks/no_direct_tool_invocation.py).
#
# Activation: `just bootstrap` installs the git-hook-wrapper from
# dev-tooling/git-hook-wrapper.sh into .git/hooks/pre-commit,
# .git/hooks/pre-push, and .git/hooks/commit-msg. The wrapper
# invokes `mise exec lefthook -- lefthook run <hook-name> "$@"` so
# the gate fires regardless of shell config and commit-msg argv[1]
# (the commit-message file path) reaches the red-green-replay hook.

pre-commit:
  commands:
    00-refuse-primary-commit:
      run: ./dev-tooling/refuse-primary-commit.sh
    01-lint-autofix-staged:
      run: just lint-autofix-staged
    02-commit-pairs-source-and-test:
      run: just check-commit-pairs-source-and-test
    03-check-pre-commit:
      run: just check-pre-commit

commit-msg:
  commands:
    00-refuse-primary-commit:
      run: ./dev-tooling/refuse-primary-commit.sh
    01-red-green-replay:
      run: just check-red-green-replay {1}

pre-push:
  commands:
    check:
      run: just check-pre-push
