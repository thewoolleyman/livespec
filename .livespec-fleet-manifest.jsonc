// .livespec-fleet-manifest.jsonc — the livespec fleet membership manifest.
//
// Authority: SPECIFICATION/non-functional-requirements.md
//   §"Fleet membership contract" (accepted v108). This committed file
//   in livespec core enumerates every fleet repo (the `fleet` array)
//   and its repo class, plus an optional `adopters` array.
//   Livespec core owns fleet-level facts (precedent: the copier
//   template at `templates/orchestrator-plugin/` is already core-hosted and
//   sibling-consumed per `contracts.md` §"Shared content sync — copier
//   template"); per-repo facts stay in consumer-local config.
//
// Consumers (both fetch this file from livespec master at run time):
//   - the dev-tooling fleet-conformance check (assert mode), which
//     derives each member's per-class obligations from the shared
//     contract definition in livespec-dev-tooling;
//   - the release fan-out (reusable-release-dispatch.yml), with the
//     GitHub `livespec-sibling` topic demoted to a discovery safety
//     net (a repo matching `livespec-*` naming or carrying the topic
//     but absent here is a conformance finding).
//
// Repo birth procedure (per the same spec section): scaffold (via the
// copier template where the class has one) → register HERE first →
// run `wire-fleet-member` → fleet conformance green. Register-first
// makes a half-wired new repo red fleet CI rather than an invisible
// straggler.
//
// `fleet` entries are { repo, class } where `class` is one of:
// core / enforcement-suite / impl-plugin / driver-plugin / library / console.
// (`console` is the Control-Plane operator console — a non-pin-consuming
// member: it carries a livespec-dev-tooling pin but ships none of the three
// pin-and-bump shim workflows; see livespec-dev-tooling contracts.md
// §"Bump-pin policy".)
//
// `adopters` entries are { repo, profile, posture } — governed repos
// (or families) that adopted the workflow but are NOT the livespec
// fleet (e.g. Open Brain). `profile` is the `baseline` floor plus any
// additive layers (fleet-infra / orchestrator-plugin / app); `posture`
// is one of released / pinned / none (how the adopter tracks upstream
// livespec releases). A fleet member's profile is DERIVED from its
// `class`; an adopter has no class, so it declares `profile` explicitly.
// `adopters` is empty until the first adopter registers. See
// non-functional-requirements.md §"Fleet membership contract" → "Adopters".
{
  "owner": "thewoolleyman",
  "fleet": [
    { "repo": "livespec", "class": "core" },
    { "repo": "livespec-dev-tooling", "class": "enforcement-suite" },
    { "repo": "livespec-driver-claude", "class": "driver-plugin" },
    { "repo": "livespec-driver-codex", "class": "driver-plugin" },
    { "repo": "livespec-orchestrator-beads-fabro", "class": "impl-plugin" },
    { "repo": "livespec-orchestrator-git-jsonl", "class": "impl-plugin" },
    { "repo": "livespec-runtime", "class": "library" },
    { "repo": "livespec-console-beads-fabro", "class": "console" }
  ],
  "adopters": [
    // openbrain: first registered adopter (github-app-auth D17, 2026-07-03).
    // Brings its own credential_wrapper (with-openbrain-env.sh) + its own
    // GitHub App (openbrain-pr-bot); pins the concrete livespec release tag.
    // dolt-server registration DEFERRED until its adopter wiring is driven.
    { "repo": "openbrain", "profile": ["baseline", "orchestrator-plugin"], "posture": "pinned" }
  ]
}
