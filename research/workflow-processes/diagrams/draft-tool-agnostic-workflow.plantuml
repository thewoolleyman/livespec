@startuml draft-tool-agnostic-workflow
title Tool-Agnostic Workflow — Spec / Implementation Lifecycle (DRAFT v7)

' Layout: flat (no outer containers). Vertical stacking enforced
' via `together { }` blocks grouping each side, plus aggressive
' hidden edges anchoring the WALL as a horizontal divider.

skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam BackgroundColor #fafafa
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000
skinparam ArrowFontSize 11
skinparam ArrowThickness 1.3
skinparam nodesep 16
skinparam ranksep 28
hide stereotype

skinparam rectangle {
  BackgroundColor #d6e6f5
  BorderColor #1f4768
  FontColor #111
  RoundCorner 8
}

skinparam database {
  BackgroundColor #f5ead5
  BorderColor #5a4319
  FontColor #111
}

' ============================================================
' EXTERNAL INPUT (replaces actors)
' ============================================================

rectangle "initial intent /\nprompt / instruction / seed" as Input #fffacc

' ============================================================
' SPEC SIDE — top half (grouped via `together`)
' ============================================================

together {
  rectangle "Seed" as Seed
  rectangle "Propose\nChange" as Propose
  rectangle "Critique" as Critique
  rectangle "Revise" as Revise
  rectangle "Doctor" as Doctor

  database "Specification" as Spec
  database "Proposed\nChanges" as PCQueue
  database "Specification\nHistory" as History
}

' ============================================================
' WALL — horizontal divider
' ============================================================

rectangle "═══════════  SPEC  (prescriptive)   ▏   IMPLEMENTATION  (descriptive)  ═══════════" as Wall #f5d76e

' ============================================================
' IMPLEMENTATION SIDE — bottom half (grouped via `together`)
' ============================================================

together {
  rectangle "Capture\nImpl Drift" as CaptureImplDrift
  rectangle "Implement" as Implement
  rectangle "Capture\nSpec Drift" as CaptureSpecDrift
  rectangle "Capture\nMemo" as CaptureMemo
  rectangle "Process\nMemos" as ProcessMemos

  database "Implementation" as Impl
  database "Work Items" as WorkItems
  database "Memos" as Memos
  database "Persistent\nAgent Knowledge" as AgentKnowledge
}

' ============================================================
' WALL ANCHORING (force WALL between the two together-groups)
' ============================================================

Input -[hidden]down-> Seed

Seed     -[hidden]down-> Wall
Propose  -[hidden]down-> Wall
Critique -[hidden]down-> Wall
Revise   -[hidden]down-> Wall
Doctor   -[hidden]down-> Wall
Spec     -[hidden]down-> Wall
PCQueue  -[hidden]down-> Wall
History  -[hidden]down-> Wall

Wall -[hidden]down-> CaptureImplDrift
Wall -[hidden]down-> Implement
Wall -[hidden]down-> CaptureSpecDrift
Wall -[hidden]down-> CaptureMemo
Wall -[hidden]down-> ProcessMemos
Wall -[hidden]down-> Impl
Wall -[hidden]down-> WorkItems
Wall -[hidden]down-> Memos
Wall -[hidden]down-> AgentKnowledge

' Intra-spec layout
Seed -[hidden]down-> Spec
Spec -[hidden]down-> PCQueue
PCQueue -[hidden]down-> Revise
Revise -[hidden]down-> History
History -[hidden]down-> Doctor
Seed -[hidden]right-> Propose
Propose -[hidden]right-> Critique

' Intra-impl layout
CaptureImplDrift -[hidden]down-> WorkItems
WorkItems -[hidden]down-> Implement
Implement -[hidden]down-> Impl
Impl -[hidden]down-> CaptureSpecDrift
CaptureImplDrift -[hidden]right-> CaptureMemo
CaptureMemo -[hidden]down-> Memos
Memos -[hidden]down-> ProcessMemos
ProcessMemos -[hidden]down-> AgentKnowledge

' ============================================================
' VISIBLE EDGES (data flow)
' ============================================================

Input --> Seed

' Spec lifecycle
Seed --> Spec
Propose --> PCQueue
PCQueue --> Revise
Revise --> Spec
Revise --> History
Spec --> Critique
Critique --> PCQueue
Spec --> Doctor
History --> Doctor

' Cross-boundary: SPEC ⇣ IMPL
Spec -[#a02020,thickness=2]-> CaptureImplDrift
Spec -[#a02020,thickness=2]-> CaptureSpecDrift

' Impl gap lifecycle
Impl --> CaptureImplDrift
CaptureImplDrift --> WorkItems
WorkItems --> Implement
Implement --> Impl
Implement --> WorkItems

' Spec-drift detection
Impl --> CaptureSpecDrift

' Cross-boundary: IMPL ⇡ SPEC
CaptureSpecDrift -[#a02020,thickness=2]-> Propose

' Memo lifecycle
CaptureMemo --> Memos
Memos --> ProcessMemos
ProcessMemos --> WorkItems : impl-bound
ProcessMemos --> AgentKnowledge : persistent

' Cross-boundary: IMPL ⇡ SPEC
ProcessMemos -[#a02020,thickness=2]-> Propose : spec-bound
Memos -[#a02020,thickness=2]-> Doctor : untriaged

@enduml
