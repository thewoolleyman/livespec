@startuml draft-tool-agnostic-workflow
title Tool-Agnostic Workflow — Spec / Implementation Lifecycle (DRAFT v3)

' Vertical stacking: SPEC SIDE on top, IMPLEMENTATION SIDE below.
' Arrow direction = data flow.
' Cross-boundary arrows colored to flag them as hard contracts.

!pragma layout smetana
top to bottom direction

' --- Styling ------------------------------------------------

skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam BackgroundColor #fafafa
skinparam ArrowColor #333
skinparam ArrowFontColor #111
skinparam ArrowFontSize 11

skinparam package {
  FontColor #111
  FontSize 13
  FontStyle bold
  BorderColor #555
  BorderThickness 2
}

' Skills / commands: rounded light-blue rectangles
skinparam rectangle {
  BackgroundColor #d6e6f5
  BorderColor #3a6a9a
  FontColor #111
  RoundCorner 8
}

' Artifacts / stores: tan cylinders
skinparam database {
  BackgroundColor #f5ead5
  BorderColor #8a6b3a
  FontColor #111
}

skinparam actor {
  BackgroundColor #ffffff
  BorderColor #111
  FontColor #111
}

' --- Actors -------------------------------------------------

actor "User" as User
actor "Agent" as Agent

' --- SPEC SIDE (top) ---------------------------------------

package "SPEC SIDE  ▏ prescriptive" as SpecPkg #fde8ec {

  rectangle "Seed" as Seed
  rectangle "Propose\nChange" as Propose
  rectangle "Critique" as Critique
  rectangle "Revise" as Revise
  rectangle "Doctor" as Doctor

  database "Specification" as Spec
  database "Proposed\nChanges" as PCQueue
  database "Specification\nHistory" as History
}

' --- IMPLEMENTATION SIDE (bottom) ---------------------------

package "IMPLEMENTATION SIDE  ▏ descriptive" as ImplPkg #e3f0e3 {

  rectangle "Capture\nImpl Drift" as CaptureImplDrift
  rectangle "Implement" as Implement
  rectangle "Capture\nSpec Drift" as CaptureSpecDrift
  rectangle "Capture\nMemo" as CaptureMemo
  rectangle "Process\nMemos" as ProcessMemos

  database "Implementation" as Impl
  database "Work Items" as WorkItems
  database "Memos" as Memos
  database "Persistent\nAgent Knowledge" as AgentKnowledge
}

' --- Actor entry points (data flow: actor → skill) ---------

User --> Seed
User --> Propose
User --> Revise
Agent --> CaptureMemo
Agent --> Implement

' --- Spec lifecycle (data flow within SPEC SIDE) -----------

Seed --> Spec
Propose --> PCQueue
PCQueue --> Revise
Revise --> Spec
Revise --> History
Spec --> Critique
Critique --> PCQueue
Spec --> Doctor
History --> Doctor

' --- Cross-boundary: SPEC ⇣ IMPL (prescription read) -------

Spec -[#a02020,thickness=2]-> CaptureImplDrift

' --- Implementation gap lifecycle (within IMPL SIDE) -------

Impl --> CaptureImplDrift
CaptureImplDrift --> WorkItems
WorkItems --> Implement
Implement --> Impl
Implement --> WorkItems

' --- Spec drift lifecycle (within IMPL SIDE) ---------------

Impl --> CaptureSpecDrift

' --- Cross-boundary: IMPL ⇡ SPEC (drift feedback) ----------

CaptureSpecDrift -[#a02020,thickness=2]-> Propose

' --- Memo lifecycle (within IMPL SIDE) ---------------------

CaptureMemo --> Memos
Memos --> ProcessMemos
ProcessMemos --> WorkItems : impl-bound
ProcessMemos --> AgentKnowledge : persistent

' --- Cross-boundary: IMPL ⇡ SPEC (spec-bound memo) ---------

ProcessMemos -[#a02020,thickness=2]-> Propose : spec-bound

' --- Cross-boundary: IMPL ⇡ SPEC (doctor hygiene query) ----
' Data flows Memos → Doctor (untriaged inventory).

Memos -[#a02020,thickness=2]-> Doctor : untriaged

' --- Hidden layout edges to force vertical package stacking -
' PlantUML deployment diagrams default to side-by-side package
' layout regardless of `top to bottom direction`. These hidden
' edges from many spec-side nodes to impl-side nodes bias the
' layout engine to stack IMPLEMENTATION SIDE below SPEC SIDE.

Seed -[hidden]down-> CaptureImplDrift
Spec -[hidden]down-> Impl
PCQueue -[hidden]down-> WorkItems
Revise -[hidden]down-> Implement
History -[hidden]down-> AgentKnowledge
Critique -[hidden]down-> ProcessMemos
Doctor -[hidden]down-> CaptureSpecDrift
Propose -[hidden]down-> CaptureMemo

@enduml
