@startuml contract-and-reference-implementations
title LiveSpec — contract + reference implementations\n(architecture decided 2026-06-09; supersedes orchestration-layers)

skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam BackgroundColor #fafafa
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000
skinparam ArrowFontSize 11
skinparam ArrowThickness 1.3
skinparam nodesep 16
skinparam ranksep 26
hide stereotype
skinparam componentStyle rectangle

skinparam package {
  FontColor #111
  FontSize 13
  FontStyle bold
  BorderColor #444
  BorderThickness 2
}

skinparam rectangle {
  BorderColor #1f4768
  FontColor #111
  RoundCorner 8
}

actor "HUMAN" as human

' ============================================================
' DRIVER — one per agent runtime
' ============================================================

package "DRIVER (one per agent runtime)\nlivespec-driver-{claude,codex,opencode,pi}" as driver #eef4fb {
  rectangle "interactive driver\n(thin: binds core's spec-side CLIs\n+ harness-neutral prose to ONE\ntool runtime)" as drv #d6e6f5
}

' ============================================================
' CORE
' ============================================================

package "CORE — livespec\n(agnostic to BOTH Driver and orchestrator)" as core #fde8ec {
  rectangle "SPECIFICATION/ tree" as spec
  rectangle "spec-side reference CLIs\nseed / propose-change / revise /\ncritique / doctor / prune-history\n(config-named, each overridable)" as scli
  rectangle "harness-neutral prose" as prose
  rectangle ".livespec.jsonc — single wiring table\nnames spec-side CLIs (defaulted)\n+ the 3 orchestrator CLIs" as cfg #ffe9c9
}

' ============================================================
' ORCHESTRATOR — one of N, self-contained
' ============================================================

package "ORCHESTRATOR (one of N; self-contained)\nreference assemblies: git-jsonl (serial; homegrown logic)\n· Beads/Dolt + Fabro (parallel; the dogfood default)" as orch #e3f0e3 {

  rectangle "spec-reader CLI\n(API undefined; exposes spec\nBY CATEGORY — categorizes,\nnever conceals)" as rdr #ccddee
  rectangle "gap-capture CLI\n(detection method private:\nmechanical / LLM / human)" as gap #ccddee
  rectangle "drift-capture CLI" as drift #ccddee

  package "INTERNAL — invisible to core AND Driver" as internals #f0f0e8 {
    rectangle "DISPATCHER\npolls Ledger, invokes Loop,\nwrites status back;\nOWNS PARALLELISM" as dispatcher
    rectangle "LEDGER\nwork-items + depends_on graph;\nconcurrent-write system of record\n(Beads/Dolt | git-jsonl)" as ledger
    rectangle "LOOP\nper-work-item producer\n(homegrown | Fabro)" as loop
    rectangle "orchestrator-shipped SKILL.md\nfront-ends (interactive gap/drift\nconsent dialogue; in-repo for now,\nplugin publication deferred)" as oskills #d6e6f5
  }
}

cloud "IMPLEMENTATION\n(the work product: code / tests / config / infra\nthe spec is FOR)" as impl

' ============================================================
' Edges — Driver -> Core (the Driver's ONLY dependencies)
' ============================================================

human --> drv : drives the spec\nlifecycle interactively
human --> oskills : interactive gap/drift\nconsent (orchestrator-owned)

drv ..> prose : [D1] vendors core, reads\nprose by relative path
drv --> scli : [D2] wraps + invokes\nspec-side CLIs
cfg ..> drv : [D3] names the\nspec-side CLIs

' ============================================================
' Edges — Orchestrator <-> Core (all machine-path)
' ============================================================

cfg ..> orch : [O1] names the 3 orchestrator CLIs\n(core knows names + callability ONLY)
rdr --> spec : [O2] reads BY CATEGORY
drift --> scli : [O3] invokes the injected\npropose-change CLI\n(files proposed-changes;\nmachine files, HUMAN accepts)
scli ..> orch : [O4] doctor: every config-named\nCLI resolves + is callable\n(callability, nothing more)

' ============================================================
' Edges — orchestrator internals + implementation
' ============================================================

gap <.. rdr : spec-reader injected
drift <.. rdr : spec-reader injected
gap --> ledger : writes gaps\n(gap CORRECTS the\nimplementation)
oskills ..> gap : fronts
oskills ..> drift : fronts
dispatcher <--> ledger : ready items /\nstatus writeback
dispatcher --> loop : invokes per\nwork-item
loop --> impl : produces
impl ..> drift : realized artifact\nteaches back\n(drift CORRECTS the spec)

' ============================================================
' Notes
' ============================================================

note bottom of driver
  ZERO direct Driver <-> orchestrator dependencies
  (load-bearing invariant). Forbidden both ways:
  the Driver never reads orchestrator prose;
  the orchestrator never calls back into the Driver.
end note

note bottom of orch
  Self-contained: prose / prompts / store / loop PRIVATE.
  Interactive dialogue is orchestrator-owned via its own
  in-repo SKILL.md front-ends (decision 2026-06-09).
  If LLM-driven without its own runtime, it shells a model
  CLI as a subprocess — depends on "a model is invokable",
  NOT on the Driver. Ledger/Loop/Dispatcher is internal
  decomposition guidance, never core contract surface.
end note

note bottom of core
  Doctor is NOT privileged: config-named and overridable
  like any other spec-side CLI. Its entire cross-boundary
  job is CLI callability. Core never sees work-items,
  gaps, stores, or dependency graphs.
end note

@enduml
