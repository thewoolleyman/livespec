// Project-local livespec configuration for livespec-core (this repo).
//
// Authority: SPECIFICATION/contracts.md
//   §"Cross-repo coordination — pin-and-bump"
{
  "template": "livespec",
  "spec_root": "SPECIFICATION",
  // Declared agent-runtime harnesses for the Conformance Pattern's cross-harness
  // plugin-resolution concern (concern #2), read by livespec-dev-tooling's
  // check-plugin-resolution Verifier (SPECIFICATION/non-functional-requirements.md
  // §"Conformance Pattern"). Core is an artifact carrier — the /livespec:* surface
  // ships from the per-runtime Driver plugins, not core — so both are EXEMPT.
  "harnesses": {
    "claude": { "status": "exempt", "reason": "core is an artifact carrier; the /livespec:* surface ships from the per-runtime Driver plugins, not core" },
    "codex":  { "status": "exempt", "reason": "core is an artifact carrier; the /livespec:* surface ships from the per-runtime Driver plugins, not core" }
  },
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  // Credential-injection wrapper (fleet default) prefixed to bd-backed CLIs so a bare
  // invocation self-heals its tenant secret (BEADS_DOLT_PASSWORD) by re-exec — per
  // SPECIFICATION/non-functional-requirements.md §"Fleet secrets". An opaque argv prefix;
  // swapping the secret backend (aws-vault/chamber/…) is a config edit, not code.
  "credential_wrapper": ["/usr/local/bin/with-livespec-env.sh", "--"],
  "livespec-orchestrator-beads-fabro": {
    "format": "beads",
    "compat": { "livespec": ">=0.1.0,<1.0.0", "pinned": "v0.20.1" },
    // Per-repo beads tenant CONNECTION block. The tenant DB name is the load-bearing tenant
    // identity (database == server_user == tenant — one <=32-char Dolt name serving all three).
    // The beads issue-ID `prefix` is bd's server-stored create-prefix; it is DECOUPLED from the
    // tenant DB name and need NOT equal it (it MAY be a short readable alias). For THIS repo the
    // prefix happens to equal the tenant (`livespec`), but that equality is no longer a required
    // rule. The tenant PASSWORD is deliberately ABSENT — supplied only via the BEADS_DOLT_PASSWORD
    // env var at bd-call time, never committed. TCP-only (the dolt.sock is not reachable by
    // sandboxed callers), so no `socket` key.
    "connection": {
      "tenant": "livespec",
      "prefix": "livespec",
      "database": "livespec",
      "server_user": "livespec",
      "server_host": "127.0.0.1",
      "server_port": 3307,
      "fake": false
    },
    // Autonomous-mode levers (maintainer-directed 2026-07-20). Two of the three
    // policy settings in SPECIFICATION/contracts.md §"The three policy settings"
    // are moved off their safe defaults so ready work is ADMITTED and ACCEPTED
    // without a human valve:
    //   auto_approve_ready: true      — pending-approval → ready with no human.
    //   acceptance_mode: "ai-only"    — post-merge acceptance without a human.
    // The third lever, `merge_on_review_cap`, deliberately STAYS at its safe
    // `false` default and is NOT listed here: a review that cannot converge
    // within `review_fix_cap` rounds is precisely the case that must reach a
    // human, per the design record cited in that section. A design-human-gated
    // (spec-change-tier) item still cannot auto-approve regardless of these.
    //
    // EDIT THIS BLOCK BY HAND. Do NOT use `drive --action set-config:<k>:<v>`:
    // that surface round-trips the file through json.dumps and silently strips
    // every comment here while reporting green — tracked as bd-ib-lmi5.
    "dispatcher": {
      "auto_approve_ready": true,
      "acceptance_mode": "ai-only"
    }
  },
  // Allowlist for cross-repo spec-heading references per
  // SPECIFICATION/constraints.md §"Allowlist mechanism".
  "external_references": {
    "livespec-dev-tooling": [
      "SPECIFICATION/contracts.md §\"Shared check inventory\"",
      "SPECIFICATION/contracts.md §\"Cross-repo coordination automation surface\"",
      "SPECIFICATION/contracts.md §\"Sibling discovery\"",
      "SPECIFICATION/contracts.md §\"Semver discipline\"",
      "SPECIFICATION/contracts.md §\"Bump-pin policy\"",
      "SPECIFICATION/contracts.md §\"`reusable-release-dispatch.yml`\""
    ],
    "openbrain": [
      "SPECIFICATION/constraints.md §\"Merged-branch cleanup\""
    ]
  },
  // Planning/work-item-resolution registry. These targets are the repo slugs
  // accepted by cross-tenant DependsOnEntry refs (`sibling_work_item`,
  // `pull_request`, and `branch`). Do not use this block as an input to
  // Python check-conformance gates; non-Python siblings can legitimately live
  // here for planning only.
  "cross_repo_targets": {
    "livespec": {
      "github_url": "https://github.com/thewoolleyman/livespec",
      "local_clone": "/data/projects/livespec",
      "default_branch": "master"
    },
    "livespec-orchestrator-git-jsonl": {
      "github_url": "https://github.com/thewoolleyman/livespec-orchestrator-git-jsonl",
      "local_clone": "/data/projects/livespec-orchestrator-git-jsonl",
      "default_branch": "master"
    },
    "livespec-dev-tooling": {
      "github_url": "https://github.com/thewoolleyman/livespec-dev-tooling",
      "local_clone": "/data/projects/livespec-dev-tooling",
      "default_branch": "master"
    },
    "livespec-console-beads-fabro": {
      "github_url": "https://github.com/thewoolleyman/livespec-console-beads-fabro",
      "local_clone": "/data/projects/livespec-console-beads-fabro",
      "default_branch": "master"
    }
  },
  // Code-conformance registry for doctor-wiring-completeness-cross-repo. This
  // list is deliberately narrower than the planning registry: it contains only
  // Python siblings expected to wire the fleet's canonical Python check slugs.
  "cross_repo_conformance_targets": {
    "livespec-orchestrator-git-jsonl": {
      "github_url": "https://github.com/thewoolleyman/livespec-orchestrator-git-jsonl",
      "local_clone": "/data/projects/livespec-orchestrator-git-jsonl",
      "default_branch": "master"
    },
    "livespec-dev-tooling": {
      "github_url": "https://github.com/thewoolleyman/livespec-dev-tooling",
      "local_clone": "/data/projects/livespec-dev-tooling",
      "default_branch": "master"
    }
  }
}
